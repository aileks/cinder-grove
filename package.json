{
  "name": "cinder-grove",
  "displayName": "Cinder Grove",
  "description": "A warm, muted dark theme for Visual Studio Code that's easy on the eyes.",
  "version": "1.0.1",
  "publisher": "aileks",
  "author": {
    "name": "Caspian Harper"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=24"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark theme",
    "color theme",
    "warm",
    "muted",
    "earthy",
    "cinder",
    "grove",
    "neovim"
  ],
  "pricing": "Free",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1B1916",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aileks/cinder-grove.git"
  },
  "homepage": "https://github.com/aileks/cinder-grove",
  "bugs": {
    "url": "https://github.com/aileks/cinder-grove/issues"
  },
  "vsce": {
    "baseImagesUrl": "https://raw.githubusercontent.com/aileks/cinder-grove/main"
  },
  "scripts": {
    "check": "node scripts/validate-theme.mjs && vsce ls",
    "package": "npm run check && vsce package"
  },
  "contributes": {
    "themes": [
      {
        "id": "cinder-grove",
        "label": "Cinder Grove",
        "uiTheme": "vs-dark",
        "path": "./themes/cinder-grove-color-theme.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "3.9.2"
  }
}
